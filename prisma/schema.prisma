datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  SUPER_ADMIN
  MANAGER
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String?
  email     String   @unique
  password  String
  role      UserRole @default(MANAGER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Building {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  address       String
  totalFloors   Int      @default(0)
  totalFlats    Int      @default(0)
  occupancyRate Float    @default(0.0) // Cached value
  ratePerUnit   Float    @default(10.0) // Electricity rate per unit
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  floors Floor[]
  flats  Flat[]
}

model Floor {
  id         String @id @default(auto()) @map("_id") @db.ObjectId
  buildingId String @db.ObjectId
  number     Int // Floor number: 0, 1, 2...
  flatsCount Int    @default(0)

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  flats    Flat[] // Flats strictly on this floor
}

enum FlatStatus {
  OCCUPIED
  VACANT
  UNDER_MAINTENANCE
}

enum ElectricityType {
  METERED
  FIXED
}

model Flat {
  id                String          @id @default(auto()) @map("_id") @db.ObjectId
  buildingId        String          @db.ObjectId
  floorId           String          @db.ObjectId
  flatNumber        String // e.g., "101", "A-1"
  rentAmount        Float
  maintenanceAmount Float           @default(0.0)
  depositAmount     Float           @default(0.0)
  electricityType   ElectricityType @default(METERED)
  status            FlatStatus      @default(VACANT)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  building Building  @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  floor    Floor     @relation(fields: [floorId], references: [id], onDelete: Cascade)
  Tenant   Tenant[]
  payments Payment[]
  meterReadings MeterReading[]
}

model Tenant {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  fullName         String
  phone            String
  aadhaarNumber    String? // Sensitive, encrypt in app logic if needed, or rely on DB security
  occupantsCount   Int       @default(1)
  leaseStartDate   DateTime
  leaseEndDate     DateTime?
  assignedFlatId   String?   @db.ObjectId
  emergencyContact String?
  notes            String?
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  flat     Flat?     @relation(fields: [assignedFlatId], references: [id])
  payments Payment[]
}

enum PaymentStatus {
  PAID
  PARTIAL
  OVERDUE
  PENDING
}

enum PaymentMethod {
  CASH
  UPI
  BANK_TRANSFER
  CHEQUE
  OTHER
}

model Payment {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  tenantId        String        @db.ObjectId
  flatId          String        @db.ObjectId
  month           DateTime // First day of the month for which rent is paid
  rentDue         Float
  maintenanceDue  Float
  electricityDue  Float         @default(0.0)
  arrears         Float         @default(0.0) // Previous month's balance carried forward
  totalDue        Float
  amountPaid      Float         @default(0.0)
  balance         Float         @default(0.0)
  status          PaymentStatus @default(PENDING)
  paymentDate     DateTime?
  paymentMethod   PaymentMethod?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  flat   Flat   @relation(fields: [flatId], references: [id])
}

model MeterReading {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  flatId      String   @db.ObjectId
  reading     Float
  readingDate DateTime @default(now())
  month       Int      // 0-11
  year        Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  flat Flat @relation(fields: [flatId], references: [id])

  @@unique([flatId, month, year])
}
